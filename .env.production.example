# ---------------------------------------------------------------------------
# KelasKita - Production Environment Variables Example
# Ganti nama file ini menjadi .env.production untuk deployment ke Cloud Run.
# ---------------------------------------------------------------------------

FLASK_ENV=production
SECRET_KEY=  # Isi dengan token_hex 64 karakter (mis. python -c "import secrets; print(secrets.token_hex(32))")
APP_URL=https://your-app-domain.run.app

# Database Connection (GCP Cloud SQL MySQL / PlanetScale / TiDB Cloud)
# Format: mysql+pymysql://user:password@host:port/database
DATABASE_URL=mysql+pymysql://user:password@host:port/database

# (Opsional) Jika menggunakan Cloud SQL Auth Proxy
# CLOUD_SQL_CONNECTION_NAME=project:region:instance-name

# Email/SMTP Notifications Configuration
MAIL_PROVIDER=smtp
MAIL_FROM_NAME=KelasKita
MAIL_FROM_EMAIL=no-reply@yourdomain.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_USE_TLS=true
